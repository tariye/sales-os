<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "https://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.salesos.research-ingest</string>

    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/ruby</string>
      <string>/Users/admin/Library/Mobile Documents/com~apple~CloudDocs/Downloads/intel-network/scripts/update_research.rb</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/admin/Library/Mobile Documents/com~apple~CloudDocs/Downloads/intel-network</string>

    <key>StartInterval</key>
    <integer>1800</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/admin/Library/Mobile Documents/com~apple~CloudDocs/Downloads/intel-network/data/ingest.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/admin/Library/Mobile Documents/com~apple~CloudDocs/Downloads/intel-network/data/ingest-error.log</string>
  </dict>
</plist>
